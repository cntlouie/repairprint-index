{
  "name": "repairprint-index",
  "version": "0.1.0",
  "private": true,
  "description": "Builder-ready bootstrap for an evidence-backed 3D printable repair-part fitment index.",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm run test && npm run content:check && npm run bootstrap:check && npm run secrets:check && npm run import:check && npm run db:gate && npm run build && npm run sitemap:gate",
    "bootstrap:check": "node --import tsx scripts/check-bootstrap.ts",
    "secrets:check": "node --import tsx scripts/check-secrets.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --import tsx scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node --import tsx scripts/seed.ts",
    "db:check": "node --import tsx scripts/check-database.ts",
    "db:ledger:check": "node --import tsx scripts/check-migration-ledger.ts",
    "db:auth-audit:check": "node --import tsx scripts/check-auth-audit-foundation.ts",
    "submissions:key-pin": "node --conditions=react-server --import tsx scripts/provision-submission-hmac-key-pin.ts",
    "submissions:cleanup": "node --conditions=react-server --import tsx scripts/cleanup-submissions.ts",
    "media:storage": "node --conditions=react-server --import tsx scripts/provision-private-media-storage.ts",
    "media:cleanup": "node --conditions=react-server --import tsx scripts/cleanup-private-media.ts",
    "sources:links": "node --conditions=react-server --import tsx scripts/check-source-links.ts",
    "db:gate": "node --import tsx scripts/check-database-gate.ts",
    "sitemap:gate": "node --import tsx scripts/check-production-render.ts",
    "sitemap:http": "node --import tsx scripts/check-sitemap-http.ts",
    "structured-data:gate": "playwright test tests/browser/wp11-structured-data.spec.ts",
    "accessibility:gate": "playwright test tests/browser/wp11-accessibility.spec.ts",
    "performance:gate": "playwright test tests/browser/wp11-performance.spec.ts",
    "analytics:browser:gate": "playwright test tests/browser/wp11-analytics.spec.ts",
    "browser:gate": "playwright test",
    "analytics:report": "node --import tsx scripts/report-private-analytics.ts",
    "render:gate": "npm run sitemap:gate",
    "import:csv": "node --import tsx scripts/import-csv.ts",
    "import:check": "node --import tsx scripts/check-import-fixture.ts",
    "content:check": "node --import tsx scripts/check-content.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "drizzle-orm": "0.45.2",
    "ipaddr.js": "2.4.0",
    "jose": "^6.2.3",
    "next": "16.2.10",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "sharp": "^0.35.3",
    "uuid": "^14.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
