# The scaffold is deliberately non-indexable and uses fictional data in demo mode.
DEMO_MODE=true
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Crawler eligibility also requires this exact production marker. Preview/staging use
# their own names and stay blocked even if another setting is wrong.
REPAIRPRINT_DEPLOYMENT_ENV=development
# Explicit reviewed HTTPS notice form/contact page. Empty keeps launch indexing blocked.
NOTICE_CONTACT_URL=

# WP-11 aggregate-only first-party analytics. No provider or credential is selected.
# Runtime collection remains disabled until a reviewed production decision supplies the
# exact mode and the separately credentialed repairprint_analytics_service URL.
ANALYTICS_MODE=disabled
ANALYTICS_DATABASE_URL=

# Start PostgreSQL with: docker compose up -d db
DATABASE_URL=postgres://repairprint:repairprint@localhost:5432/repairprint
DATABASE_DIRECT_URL=postgres://repairprint:repairprint@localhost:5432/repairprint
# Destructive database checks refuse every database name except repairprint_test.
DATABASE_TEST_URL=postgres://repairprint:repairprint@localhost:5432/repairprint_test

# Private contribution writes use a separately credentialed, least-privilege database role.
# Leave this unset until migration 0006 is applied and that role has a deployment credential.
# The role cannot change the key pin or directly update/delete immutable intake/contact rows.
SUBMISSION_DATABASE_URL=

# Anonymous contribution protection. Turnstile site keys are browser-safe; its secret and the
# 64-hex (`openssl rand -hex 32`) HMAC secret are server-only. Never trim or reuse the key.
# Demo mode uses a non-persisting official test-token path.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
SUBMISSION_HMAC_SECRET=
# Before setting DEMO_MODE=false for persistent intake, provision the commitment with an
# owner/admin DATABASE_URL: npm run submissions:key-pin. The database never stores this key.
# Changing a live key fails closed; restore the original key rather than replacing the pin.

# Counsel/operations select these versioned retention values before persistent intake is enabled.
# Production mode fails closed when any required value is absent or invalid; no legal duration is
# implied by this template. The optional cleanup batch size defaults to 100 and is capped at 1000.
SUBMISSION_RETENTION_POLICY_VERSION=
SUBMISSION_RETENTION_DAYS=
SUBMISSION_CONTACT_RETENTION_DAYS=
SUBMISSION_CLEANUP_BATCH_SIZE=

# Supabase Auth is invite-only. Public signup and anonymous sign-in stay disabled.
# The service-role key is server-only and is used solely by reviewed staff-invite orchestration.
SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Browser-safe Auth configuration for the private staff login. The publishable key is not a service secret.
NEXT_PUBLIC_SUPABASE_URL=https://project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# WP-09 private media. Production has no legal or storage defaults and fails closed.
MEDIA_CAPABILITY_SECRET=
MEDIA_QUARANTINE_BUCKET=
MEDIA_PRIVATE_BUCKET=
MEDIA_TERMS_VERSION=
MEDIA_PRIVACY_VERSION=
MEDIA_RETENTION_POLICY_VERSION=
MEDIA_RETENTION_DAYS=
MEDIA_CLEANUP_BATCH_SIZE=

# WP-10 source adapters/link health. No real adapter, credential, or scheduler is provisioned.
# The worker URL must authenticate as exactly repairprint_source_service; owner fallback is rejected.
SOURCE_DATABASE_URL=
SOURCE_ADAPTER_MODE=disabled
SOURCE_LINK_WORKER_ACTOR_ID=
SOURCE_LINK_WORKER_ID=
SOURCE_LINK_WORKER_SECRET=
SOURCE_LINK_WORKER_ORIGIN=http://localhost:3000
